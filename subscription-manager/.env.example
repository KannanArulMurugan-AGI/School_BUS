# Environment variables for the Subscription Manager service

# Port for the application to listen on
PORT=3000

# PostgreSQL database connection URL
# Format: postgres://<user>:<password>@<host>:<port>/<database>
# For local development with Docker Compose, the host is the service name (e.g., 'postgres').
# For running outside of Docker, it would be 'localhost'.
DATABASE_URL="postgres://user:password@postgres:5432/school_bus_db"

# Path to the Firebase service account JSON file.
# In a production environment (like Cloud Run), it's often better to store the
# JSON content directly in a secret manager and load it from an environment variable.
FIREBASE_SERVICE_ACCOUNT_PATH="./serviceAccountKey.json"

# API Keys for third-party services
STRIPE_SECRET_KEY="your_stripe_secret_key_here"

# Secret key for signing custom JSON Web Tokens (JWTs) or session cookies.
# This should be a long, random, and secret string.
JWT_SECRET="replace_with_a_long_random_secret_string"
