# Environment variables for the School Runtime service

# Port for the application to listen on
PORT=3001

# PostgreSQL database connection URL
# This service might need to connect to the same database as the subscription-manager.
DATABASE_URL="postgres://user:password@localhost:5432/school_bus_db"

# Path to the Firebase service account JSON file
# This service might also require Firebase Admin SDK access.
FIREBASE_SERVICE_ACCOUNT_PATH="./serviceAccountKey.json"
